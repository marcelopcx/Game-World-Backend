# Copia este archivo a .env:
#   cp .env.example .env
#
# Necesario para cargo run y para Cargo Check del IDE (junto con build.rs).

# -----------------------------------------------------------------------------
# DATABASE_URL
# -----------------------------------------------------------------------------
# Elegí UNA de las dos opciones según dónde corras la base.
# El backend setea `search_path` desde el código (src/db/mod.rs), así que la
# URL NO necesita el parámetro `options=-csearch_path%3D...`.

# Opción A — Supabase (Session pooler, IPv4, recomendado para producción/staging)
# Reemplazá <PROJECT_REF>, <PASSWORD> y <REGION> por los valores de tu proyecto
# (Dashboard → botón verde "Connect" → tab "Session pooler").
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require

# Opción B — PostgreSQL local con Docker Compose (desarrollo offline)
DATABASE_URL=postgres://gameworld:secret123@127.0.0.1:5432/game_world

JWT_SECRET=un_secreto_largo_minimo_32_caracteres_cambiar_en_produccion
JWT_EXPIRATION_HOURS=24

HOST=0.0.0.0
PORT=8080

# Cloudinary (subidas no firmadas / Unsigned Uploads)
CLOUDINARY_CLOUD_NAME=mpc-uru
CLOUDINARY_UPLOAD_PRESET=n3n6sbhv
CLOUDINARY_FOLDER=game-world

# Avatar predeterminado al registrar (Cloudinary)
DEFAULT_AVATAR_URL=https://res.cloudinary.com/mpc-uru/image/upload/game-world/avatars/default.png

# IGDB (https://api-docs.igdb.com/#getting-started)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Mínimo de videojuegos en BD al arrancar (se completan desde IGDB si faltan)
CATALOGO_MIN_JUEGOS=1000
